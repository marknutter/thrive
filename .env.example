BETTER_AUTH_SECRET=change-me-run-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3022
DATABASE_PATH=./data/coachk.db

# App base URL (used in emails, Stripe redirects, etc.)
# APP_URL=https://yourapp.example.com

# App display name (used in emails, MFA enrollment)
# APP_NAME=CoachK

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (https://github.com/settings/developers)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email — Resend (https://resend.com)
# RESEND_API_KEY=re_...

# Stripe (https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...
